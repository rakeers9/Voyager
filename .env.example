# ── Supabase (auth + database) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Required only for the public /share/[tripId] read-only viewer
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Mapbox (basemap + Directions API) ──────────────────────────────────
# Public token; used both client-side (basemap) and server-side (/api/directions)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ── Google Places (geocoding + photos + place details) ─────────────────
GOOGLE_PLACES_API_KEY=your_google_places_key

# ── Gemini (chatbot trip planner) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_key
